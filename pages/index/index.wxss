/* 首页样式 */

/* 页面标题 */
.page-header {
  text-align: center;
  margin-bottom: 40rpx;
  padding: 20rpx 0;
  position: relative;
  padding-right: 240rpx;
}

.page-title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 15rpx;
}

.page-subtitle {
  display: block;
  font-size: 26rpx;
  color: #87CEEB;
}

.page-header-btns {
  position: absolute;
  top: 20rpx;
  right: 30rpx;
  display: flex;
  gap: 8rpx;
}

.manage-type-btn {
  padding: 10rpx 16rpx;
  background: linear-gradient(135deg, #87CEEB 0%, #4A90E2 100%);
  color: #FFFFFF;
  font-size: 22rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(135, 206, 235, 0.3);
}

.clear-data-btn {
  padding: 10rpx 16rpx;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF3B30 100%);
  color: #FFFFFF;
  font-size: 22rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(255, 59, 48, 0.3);
}

/* 统计卡片 */
.stats-card {
  margin-top: 20rpx;
}

/* 类型筛选 */
.type-filter {
  display: flex;
  gap: 15rpx;
  margin-bottom: 30rpx;
  flex-wrap: wrap;
}

.type-filter-item {
  padding: 12rpx 24rpx;
  background: rgba(135, 206, 235, 0.1);
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #666666;
  transition: all 0.3s;
}

.type-filter-item.active {
  background: linear-gradient(135deg, #87CEEB 0%, #4A90E2 100%);
  color: #FFFFFF;
  font-weight: bold;
}

.stats-row {
  display: flex;
  justify-content: space-around;
}

.weekly-stats {
  margin-top: 30rpx;
  padding-top: 30rpx;
  border-top: 1rpx solid rgba(135, 206, 235, 0.2);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-number {
  font-size: 56rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.stat-label {
  font-size: 28rpx;
  color: #999999;
}

/* 打卡区域 */
.checkin-section {
  margin: 60rpx 0;
  text-align: center;
}

.date-text {
  font-size: 36rpx;
  color: #666666;
  margin-bottom: 40rpx;
}

.checkin-btn {
  margin: 0 auto;
  width: 500rpx;
  transition: all 0.3s;
}

.checkin-btn:active {
  transform: scale(0.95);
}

.checked-btn {
  background: #E8F4F8;
  color: #87CEEB;
  border-radius: 50rpx;
  padding: 30rpx;
  font-size: 40rpx;
  font-weight: bold;
  width: 500rpx;
  margin: 0 auto;
  text-align: center;
}

/* 日历卡片 */
.calendar-card {
  margin-bottom: 40rpx;
}

.calendar-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.calendar-title {
  font-size: 36rpx;
  font-weight: bold;
}

.month-selector {
  display: flex;
  align-items: center;
  gap: 20rpx;
  font-size: 32rpx;
  color: #666666;
}

.month-selector text {
  padding: 10rpx 20rpx;
  cursor: pointer;
}

.current-month {
  font-weight: bold;
  color: #333333;
}

/* 日历网格 */
.calendar-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 10rpx;
}

.weekday {
  text-align: center;
  font-size: 28rpx;
  color: #999999;
  padding: 10rpx 0;
}

.calendar-day {
  aspect-ratio: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  border-radius: 12rpx;
  background: rgba(255, 255, 255, 0.6);
  border: 1rpx solid rgba(135, 206, 235, 0.2);
  position: relative;
  color: #999999;
}

.calendar-day.checked {
  background: linear-gradient(135deg, #9ACD32 0%, #7CB342 100%);
  color: #FFFFFF;
  font-weight: bold;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(154, 205, 50, 0.3);
}

.calendar-day.checked::after {
  content: '✓';
  position: absolute;
  bottom: 4rpx;
  right: 4rpx;
  font-size: 16rpx;
  color: rgba(255, 255, 255, 0.8);
}

.calendar-day.today {
  border: 3rpx solid #87CEEB;
  background: #E8F4F8;
  font-weight: bold;
}

.calendar-day.today.checked {
  border: none;
  background: linear-gradient(135deg, #9ACD32 0%, #7CB342 100%);
  color: #FFFFFF;
}
