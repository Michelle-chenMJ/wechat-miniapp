/* 打卡详情页样式 */

.page-title {
  font-size: 40rpx;
  font-weight: bold;
  text-align: center;
  margin: 40rpx 0;
  color: #333333;
}

/* 表单标签 */
.form-label {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 20rpx;
}

/* 类型选择 */
.type-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.type-item {
  padding: 20rpx 40rpx;
  background: #F5F5F5;
  border-radius: 40rpx;
  font-size: 28rpx;
  color: #666666;
  transition: all 0.3s;
}

.type-item.active {
  background: linear-gradient(135deg, #87CEEB 0%, #4A90E2 100%);
  color: #FFFFFF;
  font-weight: bold;
}

/* 上传区域 */
.upload-area {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.image-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.image-item image {
  width: 100%;
  height: 100%;
}

.delete-btn {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  width: 50rpx;
  height: 50rpx;
  background: rgba(0, 0, 0, 0.6);
  color: #FFFFFF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  line-height: 1;
}

.upload-btn {
  width: 200rpx;
  height: 200rpx;
  background: #F5F5F5;
  border: 2rpx dashed #CCCCCC;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  color: #CCCCCC;
}

.upload-text {
  font-size: 24rpx;
  margin-top: 10rpx;
}

/* 输入框 */
.input-field {
  width: 100%;
  padding: 24rpx;
  background: #F5F5F5;
  border-radius: 16rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.custom-type {
  margin-top: 20rpx;
  font-size: 36rpx;
  padding: 40rpx 30rpx;
  height: 120rpx;
}

.suggestions {
  margin-top: 10rpx;
  background: #FFFFFF;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.suggestion-item {
  padding: 20rpx 30rpx;
  font-size: 32rpx;
  color: #333333;
  border-bottom: 1rpx solid #F0F0F0;
}

.suggestion-item:last-child {
  border-bottom: none;
}

.suggestion-item:active {
  background: #F5F5F5;
}

.duration-input {
  font-size: 64rpx;
  font-weight: bold;
  text-align: center;
  padding: 50rpx;
  height: 180rpx;
}

.textarea-field {
  width: 100%;
  min-height: 120rpx;
  padding: 24rpx;
  background: #F5F5F5;
  border-radius: 16rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.char-count {
  text-align: right;
  font-size: 24rpx;
  color: #999999;
  margin-top: 10rpx;
}

/* 提交按钮 */
.submit-btn {
  margin-top: 60rpx;
  margin-bottom: 40rpx;
}
