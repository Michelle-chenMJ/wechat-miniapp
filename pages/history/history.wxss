/* 历史记录页样式 */

/* 页面标题 */
.page-header {
  text-align: center;
  margin-bottom: 40rpx;
  padding: 20rpx 0;
}

.page-title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 15rpx;
}

.page-subtitle {
  display: block;
  font-size: 26rpx;
  color: #87CEEB;
}

/* 统计概览卡片 */
.summary-card {
  background: linear-gradient(135deg, #87CEEB 0%, #4A90E2 100%);
  color: #FFFFFF;
}

.summary-title {
  font-size: 40rpx;
  font-weight: bold;
  text-align: center;
  margin-bottom: 30rpx;
}

.summary-stats {
  display: flex;
  justify-content: space-around;
  margin-bottom: 30rpx;
}

.summary-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.summary-number {
  font-size: 56rpx;
  font-weight: bold;
  color: #FFFFFF;
}

.summary-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 10rpx;
}

/* 成就展示 */
.achievements {
  display: flex;
  flex-wrap: wrap;
  gap: 15rpx;
  justify-content: center;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.3);
}

.achievement-item {
  background: rgba(255, 255, 255, 0.2);
  padding: 10rpx 20rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #FFFFFF;
}

/* 记录列表 */
.records-section {
  margin-top: 20rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  color: #333333;
}

/* 记录卡片 */
.record-card {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.record-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.record-date {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.record-type {
  background: #E8F4F8;
  color: #87CEEB;
  padding: 10rpx 24rpx;
  border-radius: 20rpx;
  font-size: 32rpx;
}

.record-content {
  margin-bottom: 20rpx;
}

.record-text {
  font-size: 30rpx;
  color: #666666;
  line-height: 1.6;
  margin-bottom: 10rpx;
}

.record-duration {
  font-size: 26rpx;
  color: #999999;
}

/* 媒体缩略图 */
.record-media {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.media-thumb {
  width: 100%;
  height: 100%;
}

.media-count {
  position: absolute;
  bottom: 10rpx;
  right: 10rpx;
  background: rgba(0, 0, 0, 0.6);
  color: #FFFFFF;
  padding: 5rpx 15rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}

/* 老师评价 */
.teacher-comment {
  background: #FFF9E6;
  padding: 20rpx;
  border-radius: 12rpx;
  border-left: 4rpx solid #FFD700;
}

.comment-label {
  font-size: 26rpx;
  color: #FF9800;
  font-weight: bold;
}

.comment-text {
  font-size: 28rpx;
  color: #666666;
  margin-left: 10rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 34rpx;
  color: #999999;
  margin-bottom: 10rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #CCCCCC;
}
